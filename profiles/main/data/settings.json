        "infra": "app",
        "main": "public",
        "presentation": "connection",
        "cryptography": "secure",
        "entities": "class",
        "repositories": "mappings",
        "protocols": "resource",
        "useCases": "components",
        "subcomponents": "components",
        "adapters": "connection",
        "factories": "container",
        "globals": "global",
        "ui": "views"
    },
    "material-icon-theme.files.associations": {
        "ormconfig.json": "database",
        "tsconfig.json": "tune",
        ".lintstagedrc.json": "tune"
