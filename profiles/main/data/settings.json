    "terminal.external.osxExec": "Hyper.app",
    "terminal.integrated.defaultProfile.osx": "fish",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "github.copilot.advanced": {},
    "CodeGPT.model": "gpt-4",
    "CodeGPT.query.language": "Portuguese",
    "go.toolsManagement.autoUpdate": true,
    "redhat.telemetry.enabled": true,
    "workbench.editor.empty.hint": "hidden",
    "debug.disassemblyView.showSourceCode": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "apc.electron": {
        "titleBarStyle": "hiddenInset",
        "trafficLightPosition": {
            "x": 11,
            "y": 10
        },
        "frame": false
    },
    "apc.header": {
        "height": 36
    },
    "apc.listRow": {
        "height": 24
    },
    "symbols.hidesExplorerArrows": false,
    "cursor.cpp.disabledLanguages": [
        "yaml",
        "markdown"
    ],
    "prisma.showPrismaDataPlatformNotification": false,
    "githubPullRequests.pullBranch": "never",
    "githubPullRequests.terminalLinksHandler": "github",
    "editor.multiCursorLimit": 100000,
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform"
    },
    "zig.initialSetupDone": true,
    "zig.path": "zig",
    "zig.zls.path": "/Users/pimenta/Library/Application Support/Cursor/User/globalStorage/ziglang.vscode-zig/zls_install/zls",
